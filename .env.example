# Supabase — find these in your Supabase dashboard under Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Resend — find this in your Resend dashboard under API Keys
RESEND_API_KEY=re_xxxxxxxxxxxx

# The "from" address for lead notification emails.
# Must be a verified domain in your Resend account.
RESEND_FROM_EMAIL=notifications@ascendglobal.com
